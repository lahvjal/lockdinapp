{
  "expo": {
    "name": "TINO",
    "slug": "tino-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tino.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSHealthShareUsageDescription": "TINO needs access to read your health data to track workouts and sync sleep information.",
        "NSHealthUpdateUsageDescription": "TINO needs access to write workout data to your Health app.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.tino.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "scheme": "tinoapp",
    "plugins": [
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "9603637d-cbb7-42c3-b5f4-7ede4a2b1f07"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9603637d-cbb7-42c3-b5f4-7ede4a2b1f07"
    }
  }
}
